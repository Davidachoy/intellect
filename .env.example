# LLM keys
GEMINI_API_KEY=
FEATHERLESS_API_KEY=

# Gemini-only routing and embeddings
ROUTER_MODE=auto
ROUTER_MODEL=gemini-3-flash-preview
ROUTER_MODEL_FALLBACKS=
INTELLIGENCE_MODEL=gemini-3-flash-preview
EXPLAINER_MODEL=gemini-3-flash-preview
EMBEDDING_MODEL=gemini-embedding-2

# Privacy Guard uses Featherless when FEATHERLESS_API_KEY is set.
# Without FEATHERLESS_API_KEY it falls back to deterministic local checks.
PRIVACY_GUARD_BACKEND=featherless
PRIVACY_GUARD_MODEL=Qwen/Qwen2.5-7B-Instruct

ANOMALY_DETECTOR_MODE=poll
ANOMALY_POLL_INTERVAL_SEC=5

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Web dashboard (Vite — packages/web)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:8001
VITE_DEMO_API_KEY=demo-key

# Server-only: mints short-lived JWT for browser STT (GET /speechmatics/jwt)
SPEECHMATICS_API_KEY=
