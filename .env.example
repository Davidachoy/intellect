# --- OpenAI (default): set LLM_PROVIDER=openai and OPENAI_API_KEY ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

ROUTER_MODE=auto
ROUTER_MODEL=gpt-4o-mini
ROUTER_MODEL_FALLBACKS=claude-3-5-haiku-latest,gemini/gemini-2.0-flash
INTELLIGENCE_MODEL=gpt-4o-mini
EXPLAINER_MODEL=gemini/gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-3-small
ANOMALY_DETECTOR_MODE=poll
ANOMALY_POLL_INTERVAL_SEC=5
PRIVACY_GUARD_BACKEND=litellm
PRIVACY_GUARD_MODEL=gpt-4o-mini

# --- Alternatives ---
# ROUTER_MODE=heuristic          # router sin API
# LLM_PROVIDER=gemini          # + HACKATHON_GOOGLE_TRACK=true
# PRIVACY_GUARD_BACKEND=featherless
# PRIVACY_GUARD_MODEL=Qwen/Qwen2.5-7B-Instruct
# FEATHERLESS_API_KEY=
HACKATHON_GOOGLE_TRACK=false

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Web dashboard (Vite — packages/web)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:8000
VITE_DEMO_API_KEY=demo-key
# Server-only: mints short-lived JWT for browser STT (GET /speechmatics/jwt)
SPEECHMATICS_API_KEY=
